{
  "name": "@ruban24/agex",
  "version": "0.3.3",
  "description": "A CLI runtime for running parallel AI coding tasks safely inside real repos",
  "type": "module",
  "bin": {
    "agex": "./dist/index.js",
    "agex-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "node build.js",
    "prepare": "node build.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "coding",
    "agents",
    "git",
    "worktree",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ruban-24/agex.git"
  },
  "homepage": "https://github.com/ruban-24/agex#readme",
  "bugs": {
    "url": "https://github.com/ruban-24/agex/issues"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "js-yaml": "^4.1.0",
    "simple-git": "^3.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.14.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
